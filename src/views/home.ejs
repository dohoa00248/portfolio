<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Do The Hoa – Portfolio</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/home.css" />
    <style>
      body {
        background-color: #f8fff4;
        color: #1b4332;
      }
      .navbar {
        background-color: #95d5b2 !important;
      }
      .navbar-brand,
      .nav-link {
        color: #1b4332 !important;
      }
      .hero {
        background-color: #40916c;
        color: #ffffff;
      }
      .card {
        background-color: #d8f3dc;
        border-color: #b7e4c7;
      }
      .card-title {
        color: #1b4332;
      }
      .section-title {
        color: #2d6a4f;
      }
      a {
        color: #2d6a4f;
      }
      a:hover {
        color: #1b4332;
      }
      footer {
        background-color: #95d5b2;
        color: #1b4332;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </head>
  <body class="bg-light text-dark">
    <!-- Header -->
    <header>
      <!-- Navbar -->
      <nav class="navbar navbar-expand-lg sticky-top shadow-sm">
        <div class="container">
          <a class="navbar-brand fw-bold" href="#">Do The Hoa</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#nav"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item">
                <a class="nav-link" href="#about">About</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#skills">Skills</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#projects">Projects</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#services">Services</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#contact">Contact</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/api/v1/admin/dashboard"
                  >My Dictionary</a
                >
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/api/v1/auth/signin">Signin</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/files/CV.pdf" download>
                  📄 Download CV
                </a>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- Hero Section -->
    <section
      class="py-5 text-center hero"
      id="about"
      style="position: relative"
    >
      <canvas
        id="bgCanvas"
        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%"
      ></canvas>
      <div class="container position-relative" style="z-index: 1">
        <h1 class="display-4 fw-bold">Do The Hoa</h1>
        <p class="mb-1"><strong>Phone:</strong> (+84) 967902184</p>
        <p class="mb-1">
          <strong>Email:</strong>
          <a href="mailto:dohoa00248@gmail.com" class="link-light"
            >dohoa00248@gmail.com</a
          >
        </p>
        <p class="mb-1">
          <strong>Portfolio:</strong>
          <a
            href="https://dothehoa.onrender.com"
            class="link-light"
            target="_blank"
            >dothehoa.onrender.com</a
          >
        </p>
        <p class="mb-1">
          <strong>GitHub:</strong>
          <a
            href="https://github.com/dohoa00248"
            class="link-light"
            target="_blank"
            >github.com/dohoa00248</a
          >
        </p>
        <p>
          <strong>LinkedIn:</strong>
          <a
            href="https://www.linkedin.com/in/do-hoa-35497b352/"
            class="link-light"
            target="_blank"
            >linkedin.com/in/do-hoa</a
          >
        </p>
        <hr class="bg-light" />
        <p class="lead">
          I'm an IT student who believes in constant improvement. With hands-on
          experience in web development and database management, I have worked
          on full-stack applications using JavaScript, Java, Node.js, Express,
          SQL, and NoSQL. Always eager to learn and grow through new challenges.
        </p>
        <p>
          <strong>Education:</strong> (2020–2025) – Information Technology,
          Industrial University of Ho Chi Minh City
        </p>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="container py-5" id="projects">
      <h2 class="section-title text-center mb-4">📁 Projects</h2>
      <div class="row g-4">
        <% dataList.forEach(project => { %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= project.title %></h5>
              <p><strong>Tech:</strong> <%= project.tech %></p>
              <p><%= project.description %></p>
            </div>
            <div class="card-footer bg-transparent border-top-0">
              <a href="<%= project.live %>" target="_blank">🌐 Live</a> |
              <a href="<%= project.github %>" target="_blank">GitHub</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="container py-5" id="skills">
      <h2 class="section-title text-center mb-4">🛠 Skills</h2>
      <div class="row">
        <div class="col-md-6">
          <ul class="list-unstyled">
            <li>
              <strong>Programming:</strong> Java, JavaScript, Python, HTML, CSS,
              C, PHP
            </li>
            <li>
              <strong>Backend:</strong> Node.js, Express.js, JWT, Session/Cookie
              Auth, EJS, WebSocket
            </li>
            <li><strong>Frontend:</strong> jQuery, Bootstrap</li>
            <li><strong>Architecture:</strong> OOP, MVC, RESTful APIs</li>
            <li>
              <strong>Data Analysis:</strong> Jupyter Notebook, Pandas,
              Matplotlib, Excel
            </li>
          </ul>
        </div>
        <div class="col-md-6">
          <ul class="list-unstyled">
            <li>
              <strong>Databases:</strong> MySQL, SQL Server, MongoDB (Atlas)
            </li>
            <li><strong>ORM/ODM:</strong> Sequelize, Mongoose</li>
            <li>
              <strong>Tools & Others:</strong> GitHub, Postman, JDBC, JPA,
              Apache Tomcat
            </li>
            <li>
              <strong>DevOps:</strong> Docker (Dockerfiles, containers), basic
              CI/CD (GitHub + Render)
            </li>
            <li><strong>Interests:</strong> Soccer, video games, music</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="container py-5" id="contact">
      <h2 class="section-title text-center mb-4">📧 Contact</h2>
      <p class="text-center">
        📧 Email me at
        <a href="mailto:dohoa00248@gmail.com">dohoa00248@gmail.com</a><br />
        🔗 Or visit my
        <a href="https://github.com/dohoa00248" target="_blank">GitHub</a>
      </p>
    </section>

    <!-- Footer -->
    <footer class="text-center py-3 border-top">
      <p class="mb-0">&copy; 2025 Do The Hoa. All rights reserved.</p>
    </footer>
  </body>
</html>

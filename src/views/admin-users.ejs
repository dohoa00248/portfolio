<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .sidebar {
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        width: 220px;
        background-color: #343a40;
        color: white;
        padding-top: 60px;
      }
      .sidebar a {
        color: white;
        display: block;
        padding: 10px 20px;
        text-decoration: none;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main {
        margin-left: 220px;
        padding: 20px;
        flex: 1;
      }
      .navbar {
        position: fixed;
        width: 100%;
        z-index: 1000;
      }
      .content-placeholder {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }
      table th,
      table td {
        vertical-align: middle;
      }
    </style>
  </head>
  <body class="bg-light">
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
      <span class="navbar-brand">Admin Panel</span>
      <div class="d-flex align-items-center ms-auto gap-2">
        <span class="text-white"
          >Welcome, <%= currentUser.username || "Admin" %></span
        >
        <a
          href="/api/v1/admin/users/profile"
          class="btn btn-outline-light btn-sm"
          >Update Info</a
        >
        <a href="/api/v1/auth/signout" class="btn btn-outline-light btn-sm"
          >Sign Out</a
        >
        <button id="toggleMode" class="btn btn-outline-light btn-sm">
          🌙 Dark
        </button>
      </div>
    </nav>
    <!-- Sidebar -->
    <div class="sidebar">
      <a href="/api/v1/admin/dashboard">🏠 Dashboard</a>
      <a href="/api/v1/admin/users">👥 User Management</a>
      <a href="/api/v1/admin/projects">📁 Projects</a>
      <a href="/api/v1/admin/dictionary">📚 Dictionary</a>
      <a href="/api/v1/admin/statistics">📈 Statistics</a>
    </div>
    <!-- Main Content -->
    <div class="main">
      <div class="container-fluid">
        <h2 class="mb-4">Dashboard Overview</h2>

        <!-- Cards -->
        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Total Users</h5>
              <p class="fs-4 fw-bold text-primary">123</p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Active Dictionary Entries</h5>
              <p class="fs-4 fw-bold text-success">456</p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Daily Visits</h5>
              <p class="fs-4 fw-bold text-warning">789</p>
            </div>
          </div>
        </div>

        <!-- User Table -->
        <div class="content-placeholder mt-4">
          <h5 class="mb-3">User List</h5>

          <% if (users.length === 0) { %>
          <p class="text-muted">No users found.</p>
          <% } else { %>
          <!-- Search Form -->
          <form
            action="/api/v1/admin/users/search"
            method="get"
            class="d-flex mb-3"
          >
            <input
              type="text"
              name="query"
              class="form-control me-2"
              placeholder="Search username or email"
              required
            />
            <button type="submit" class="btn btn-primary">🔍 Search</button>
          </form>

          <!-- Add User -->
          <a
            href="/api/v1/admin/users/create"
            class="btn btn-success btn-sm mb-3"
            >➕ Add New User</a
          >

          <!-- User Table -->
          <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Username</th>
                  <th>Password</th>
                  <th>Email</th>
                  <th>First name</th>
                  <th>Last name</th>
                  <th>Created At</th>
                  <th>Updated At</th>
                  <th>Role</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><%= user.username %></td>
                  <td>
                    <span
                      class="d-inline-block text-truncate"
                      style="max-width: 120px"
                      title="<%= user.password %>"
                    >
                      <%= user.password.slice(0, 5) + '...' %>
                    </span>
                  </td>
                  <td><%= user.email %></td>
                  <td><%= user.firstName %></td>
                  <td><%= user.lastName %></td>
                  <td>
                    <%= new Date(user.createdAt).toLocaleString('vi-VN', {
                    hour12: false }) %>
                  </td>
                  <td>
                    <%= new Date(user.updatedAt).toLocaleString('vi-VN', {
                    hour12: false }) %>
                  </td>
                  <td>
                    <% if (user.role === 0) { %>
                    <span class="badge bg-danger">Super Admin</span>
                    <% } else if (user.role === 1) { %>
                    <span class="badge bg-primary">Admin</span>
                    <% } else if (user.role === 2) { %>
                    <span class="badge bg-success">User</span>
                    <% } else if (user.role === 3) { %>
                    <span class="badge bg-secondary">Guest</span>
                    <% } else { %>
                    <span class="badge bg-dark">Unknown</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="btn-group" role="group">
                      <!-- Edit: visible for all -->
                      <a
                        href="/api/v1/admin/users/<%= user._id %>"
                        class="btn btn-sm btn-primary"
                        title="Edit"
                      >
                        ✏️ Edit
                      </a>
                      <a
                        href="/api/v1/admin/users/<%= user._id %>/change-password"
                        class="btn btn-sm btn-warning"
                        title="Change Password"
                      >
                        🔑 Pass
                      </a>
                      <form
                        action="/api/v1/admin/users/<%= user._id %>?_method=DELETE"
                        method="post"
                        style="display: inline"
                        onsubmit="return confirm('Are you sure to delete this user?');"
                      >
                        <button
                          type="submit"
                          class="btn btn-sm btn-danger"
                          title="Delete"
                        >
                          🗑️ Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <script>
      const toggleButton = document.getElementById('toggleMode');
      const body = document.body;
      const sidebar = document.querySelector('.sidebar');

      toggleButton.addEventListener('click', () => {
        body.classList.toggle('bg-light');
        body.classList.toggle('bg-dark');
        body.classList.toggle('text-white');
        sidebar.classList.toggle('bg-dark');
        sidebar.classList.toggle('bg-light');
        sidebar.classList.toggle('text-dark');
        toggleButton.innerHTML = toggleButton.textContent.includes('Dark')
          ? '☀️ Light'
          : '🌙 Dark';
      });
    </script>
  </body>
</html>

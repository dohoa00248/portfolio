<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .sidebar {
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        width: 220px;
        background-color: #343a40;
        color: white;
        padding-top: 60px;
      }
      .sidebar a {
        color: white;
        display: block;
        padding: 10px 20px;
        text-decoration: none;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main {
        margin-left: 220px;
        padding: 20px;
        flex: 1;
      }
      .navbar {
        position: fixed;
        width: 100%;
        z-index: 1000;
      }
      .content-placeholder {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }
    </style>
  </head>
  <body class="bg-light">
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
      <span class="navbar-brand">Admin Panel</span>
      <span class="text-white me-3"
        >Welcome, <%= user?.username || "Admin" %></span
      >
      <a href="/api/v1/auth/signout" class="btn btn-outline-light btn-sm"
        >Sign Out</a
      >
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">
      <a href="/api/v1/admin/dashboard">🏠 Dashboard</a>
      <a href="/api/v1/admin/users">👥 User Management</a>
      <a href="/api/v1/admin/dictionary">📚 Dictionary</a>
      <a href="/api/v1/admin/stats">📈 Statistics</a>
    </div>

    <!-- Main Content -->
    <div class="main">
      <div class="container-fluid">
        <h2 class="mb-4">Dashboard Overview</h2>

        <!-- Placeholder cards -->
        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="content-placeholder">
              <h5>Total Users</h5>
              <p>123 users</p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="content-placeholder">
              <h5>Active Dictionary Entries</h5>
              <p>456 entries</p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="content-placeholder">
              <h5>Daily Visits</h5>
              <p>789 visits</p>
            </div>
          </div>
        </div>

        <!-- More content if needed -->
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

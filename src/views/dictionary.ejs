<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dictionary Manager</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .sidebar {
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        width: 220px;
        background-color: #343a40;
        color: white;
        padding-top: 60px;
      }
      .sidebar a {
        color: white;
        display: block;
        padding: 10px 20px;
        text-decoration: none;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main {
        margin-left: 220px;
        padding: 20px;
        flex: 1;
      }
      .navbar {
        position: fixed;
        width: 100%;
        z-index: 1000;
      }
      .content-placeholder {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }
    </style>
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
      <span class="navbar-brand">Admin Panel</span>
      <div class="d-flex align-items-center ms-auto gap-2">
        <span class="text-white"
          >Welcome, <%= currentUser?.username || 'Admin' %></span
        >
        <a href="/api/v1/auth/signout" class="btn btn-outline-light btn-sm"
          >Sign Out</a
        >
        <button id="toggleMode" class="btn btn-outline-light btn-sm">
          🌙 Dark
        </button>
      </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">
      <a href="/api/v1/admin/dashboard">🏠 Dashboard</a>
      <a href="/api/v1/admin/users">👥 User Management</a>
      <a href="/api/v1/admin/dictionary">📚 Dictionary</a>
      <a href="/api/v1/admin/statistics">📈 Statistics</a>
    </div>

    <!-- Main Content -->
    <div class="main">
      <div class="container-fluid">
        <h2 class="mb-4">📚 Dictionary Manager</h2>
        <!-- Add New Word -->
        <div class="content-placeholder mb-4">
          <h5 class="mb-3">Add New Word</h5>
          <form action="/api/v1/admin/dictionary" method="POST">
            <div class="row g-3">
              <div class="col-md-4">
                <input
                  type="text"
                  class="form-control"
                  name="word"
                  placeholder="Word"
                  required
                />
              </div>
              <div class="col-md-4">
                <input
                  type="text"
                  class="form-control"
                  name="pronunciation"
                  placeholder="Pronunciation"
                />
              </div>
              <div class="col-md-4">
                <input
                  type="text"
                  class="form-control"
                  name="partOfSpeech"
                  placeholder="Part of Speech"
                />
              </div>
              <div class="col-md-6">
                <input
                  type="text"
                  class="form-control"
                  name="meaning"
                  placeholder="Meaning"
                  required
                />
              </div>
              <div class="col-md-6">
                <input
                  type="text"
                  class="form-control"
                  name="examples"
                  placeholder="Examples (comma separated)"
                />
              </div>
              <div class="col-12 text-end">
                <button class="btn btn-primary">➕ Add Word</button>
              </div>
            </div>
          </form>
        </div>
        <!-- FORM SEARCH -->
        <form
          action="/api/v1/admin/dictionary/search"
          method="get"
          class="d-flex mb-3"
        >
          <input
            type="text"
            name="query"
            class="form-control me-2"
            placeholder="Search Vocabulary"
            required
          />
          <button type="submit" class="btn btn-primary">🔍 Search</button>
        </form>
        <!-- Word List -->
        <div class="content-placeholder">
          <h5 class="mb-3">Vocabulary List</h5>
          <% if (vocabularies.length === 0) { %>
          <p class="text-muted">No entries found.</p>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Word</th>
                  <th>Pronunciation</th>
                  <th>Part of Speech</th>
                  <th>Meaning</th>
                  <th>Examples</th>
                  <th>Created</th>
                  <th>Updated</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% vocabularies.forEach((vocab, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><%= vocab.word %></td>
                  <td><%= vocab.pronunciation %></td>
                  <td><%= vocab.partOfSpeech %></td>
                  <td><%= vocab.meaning %></td>
                  <td>
                    <% if (Array.isArray(vocab.examples)) { %>
                    <ul class="mb-0 ps-3">
                      <% vocab.examples.forEach(ex => { %>
                      <li><%= ex %></li>
                      <% }) %>
                    </ul>
                    <% } else { %> <%= vocab.examples %> <% } %>
                  </td>
                  <td>
                    <%= new Date(vocab.createdAt).toLocaleString('vi-VN', {
                    hour12: false }) %>
                  </td>
                  <td>
                    <%= new Date(vocab.updatedAt).toLocaleString('vi-VN', {
                    hour12: false }) %>
                  </td>
                  <td>
                    <!-- Action buttons -->
                    <a
                      href="/api/v1/admin/dictionary/<%= vocab._id %>"
                      class="btn btn-sm btn-primary me-1"
                      >Edit</a
                    >
                    <form
                      action="/api/v1/admin/dictionary/<%= vocab._id %>?_method=DELETE"
                      method="post"
                      style="display: inline"
                    >
                      <button
                        type="submit"
                        class="btn btn-sm btn-danger"
                        onclick="return confirm('Are you sure?')"
                      >
                        Delete
                      </button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Script -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const toggleButton = document.getElementById('toggleMode');
      const body = document.body;
      const sidebar = document.querySelector('.sidebar');

      toggleButton.addEventListener('click', () => {
        body.classList.toggle('bg-light');
        body.classList.toggle('bg-dark');
        body.classList.toggle('text-white');
        sidebar.classList.toggle('bg-dark');
        sidebar.classList.toggle('bg-light');
        sidebar.classList.toggle('text-dark');

        if (toggleButton.textContent.includes('Dark')) {
          toggleButton.innerHTML = '☀️ Light';
        } else {
          toggleButton.innerHTML = '🌙 Dark';
        }
      });
    </script>
  </body>
</html>

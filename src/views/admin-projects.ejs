<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project Management</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: #f8f9fa;
      }
      .sidebar {
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        width: 220px;
        background-color: #343a40;
        color: white;
        padding-top: 60px;
      }
      .sidebar a {
        color: white;
        display: block;
        padding: 10px 20px;
        text-decoration: none;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main {
        margin-left: 220px;
        padding: 80px 20px 20px 20px;
        flex: 1;
      }
      .navbar {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 1000;
      }
      .content-placeholder {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }
      table th,
      table td {
        vertical-align: middle;
      }
    </style>
  </head>
  <body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
      <span class="navbar-brand">Admin Panel</span>
      <div class="d-flex align-items-center ms-auto gap-2">
        <span class="text-white"
          >Welcome, <%= currentUser.username || "Admin" %></span
        >
        <a
          href="/api/v1/admin/users/profile"
          class="btn btn-outline-light btn-sm"
          >Update Info</a
        >
        <a href="/api/v1/auth/signout" class="btn btn-outline-light btn-sm"
          >Sign Out</a
        >
        <button id="toggleMode" class="btn btn-outline-light btn-sm">
          🌙 Dark
        </button>
      </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">
      <a href="/api/v1/admin/dashboard">🏠 Dashboard</a>
      <a href="/api/v1/admin/users">👥 User Management</a>
      <a href="/api/v1/admin/projects">📁 Projects</a>
      <a href="/api/v1/admin/dictionary">📚 Dictionary</a>
      <a href="/api/v1/admin/statistics">📈 Statistics</a>
    </div>

    <!-- Main Content -->
    <div class="main">
      <div class="container-fluid">
        <h2 class="mb-4">Project Management</h2>

        <!-- Summary -->
        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Total Projects</h5>
              <p class="fs-4 fw-bold text-info"><%= totalProjects %></p>
            </div>
          </div>
        </div>

        <!-- Add Project Form -->
        <div class="content-placeholder mb-4">
          <h5 class="mb-3">Add New Project</h5>
          <form action="/api/v1/admin/projects" method="post">
            <div class="row g-3">
              <div class="col-md-4">
                <input
                  type="text"
                  name="title"
                  class="form-control"
                  placeholder="Title"
                  required
                />
              </div>
              <div class="col-md-3">
                <input
                  type="text"
                  name="tech"
                  class="form-control"
                  placeholder="Tech Stack"
                  required
                />
              </div>
              <div class="col-md-5">
                <input
                  type="text"
                  name="description"
                  class="form-control"
                  placeholder="Description"
                  required
                />
              </div>
              <div class="col-md-4">
                <input
                  type="url"
                  name="live"
                  class="form-control"
                  placeholder="Live URL"
                  required
                />
              </div>
              <div class="col-md-4">
                <input
                  type="url"
                  name="github"
                  class="form-control"
                  placeholder="Github URL"
                  required
                />
              </div>
              <div class="col-md-4 d-grid">
                <button type="submit" class="btn btn-primary">
                  ➕ Add Project
                </button>
              </div>
            </div>
          </form>
        </div>

        <!-- Projects Table -->
        <div class="content-placeholder">
          <h5 class="mb-3">Project List</h5>

          <% if (projects.length === 0) { %>
          <p class="text-muted">No projects found.</p>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Title</th>
                  <th>Tech Stack</th>
                  <th>Description</th>
                  <th>Live</th>
                  <th>Github</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% projects.forEach((project, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><%= project.title %></td>
                  <td><%= project.tech %></td>
                  <td>
                    <span
                      class="d-inline-block text-truncate"
                      style="max-width: 200px"
                      title="<%= project.description %>"
                    >
                      <%= project.description.slice(0, 60) + '...' %>
                    </span>
                  </td>
                  <td>
                    <a href="<%= project.live %>" target="_blank">🔗 Live</a>
                  </td>
                  <td>
                    <a href="<%= project.github %>" target="_blank"
                      >📁 Github</a
                    >
                  </td>
                  <td>
                    <div class="btn-group" role="group">
                      <a
                        href="/api/v1/admin/projects/<%= project._id %>"
                        class="btn btn-sm btn-primary"
                        title="Edit"
                        >✏️ Edit</a
                      >
                      <form
                        action="/api/v1/admin/projects/<%= project._id %>?_method=DELETE"
                        method="post"
                        onsubmit="return confirm('Are you sure to delete this project?');"
                        style="display: inline"
                      >
                        <button
                          type="submit"
                          class="btn btn-sm btn-danger"
                          title="Delete"
                        >
                          🗑️ Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% } %>
        </div>
      </div>
    </div>

    <script>
      const toggleButton = document.getElementById('toggleMode');
      const body = document.body;
      const sidebar = document.querySelector('.sidebar');

      toggleButton.addEventListener('click', () => {
        body.classList.toggle('bg-light');
        body.classList.toggle('bg-dark');
        body.classList.toggle('text-white');
        sidebar.classList.toggle('bg-dark');
        sidebar.classList.toggle('bg-light');
        sidebar.classList.toggle('text-dark');
        toggleButton.innerHTML = toggleButton.textContent.includes('Dark')
          ? '☀️ Light'
          : '🌙 Dark';
      });
    </script>
  </body>
</html>

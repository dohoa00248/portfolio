<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .sidebar {
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        width: 220px;
        background-color: #343a40;
        color: white;
        padding-top: 60px;
      }
      .sidebar a {
        color: white;
        display: block;
        padding: 10px 20px;
        text-decoration: none;
      }
      .sidebar a:hover {
        background-color: #495057;
      }
      .main {
        margin-left: 220px;
        padding: 20px;
        flex: 1;
        background-color: #f8f9fa;
        min-height: 100vh;
      }
      .navbar {
        position: fixed;
        width: 100%;
        z-index: 1000;
      }
      .content-placeholder {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }
    </style>
  </head>

  <body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
      <span class="navbar-brand">Admin Panel</span>
      <div class="d-flex align-items-center ms-auto gap-2">
        <span class="text-white"
          >Welcome, <%= currentUser.username || "Admin" %></span
        >
        <a
          href="/api/v1/admin/users/profile"
          class="btn btn-outline-light btn-sm"
          >Update Info</a
        >
        <a href="/api/v1/auth/signout" class="btn btn-outline-light btn-sm"
          >Sign Out</a
        >
        <button id="toggleMode" class="btn btn-outline-light btn-sm">
          🌙 Dark
        </button>
      </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">
      <a href="/api/v1/admin/dashboard">🏠 Dashboard</a>
      <a href="/api/v1/admin/users">👥 User Management</a>
      <a href="/api/v1/admin/projects">📁 Projects</a>
      <a href="/api/v1/admin/dictionary">📚 Dictionary</a>
      <a href="/api/v1/admin/statistics">📈 Statistics</a>
    </div>

    <!-- Main Content -->
    <div class="main">
      <div class="container-fluid">
        <h2 class="mb-4">Dashboard Overview</h2>

        <!-- Stats cards -->
        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Total Users</h5>
              <p class="fs-4 fw-bold text-primary"><%= totalUsers || 0 %></p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Total Vocabulary</h5>
              <p class="fs-4 fw-bold text-success">
                <%= totalVocabulary || 0 %>
              </p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="content-placeholder text-center">
              <h5>Daily Visits</h5>
              <p class="fs-4 fw-bold text-warning">789</p>
            </div>
          </div>
        </div>

        <!-- Chart -->
        <div class="content-placeholder mb-4">
          <h5 class="mb-3">Statistics Chart</h5>
          <canvas id="statsChart" height="100"></canvas>
        </div>

        <!-- User Table -->
        <div class="content-placeholder">
          <h5 class="mb-3">User List</h5>
          <% if (users.length === 0) { %>
          <p class="text-muted">No users found.</p>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Username</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Created At</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><%= user.username %></td>
                  <td><%= user.email %></td>
                  <td>
                    <%= user.role === 0 ? 'Super Admin' : user.role === 1 ?
                    'Admin' : 'User' %>
                  </td>
                  <td>
                    <%= new Date(user.createdAt).toLocaleString('vi-VN', {
                    hour12: false }) %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Chart Script -->
    <script>
      const ctx = document.getElementById('statsChart').getContext('2d');
      const statsChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Users', 'Vocabulary', 'Visits'],
          datasets: [{
            label: 'Statistics',
            data: [<%= totalUsers || 0 %>, <%= totalVocabulary || 0 %>, 789],
            backgroundColor: ['#007bff', '#28a745', '#ffc107']
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false }
          }
        }
      });
    </script>

    <!-- Toggle Mode Script -->
    <script>
      const toggleButton = document.getElementById('toggleMode');
      const body = document.body;
      const sidebar = document.querySelector('.sidebar');

      toggleButton.addEventListener('click', () => {
        body.classList.toggle('bg-light');
        body.classList.toggle('bg-dark');
        body.classList.toggle('text-white');
        sidebar.classList.toggle('bg-dark');
        sidebar.classList.toggle('bg-light');
        sidebar.classList.toggle('text-dark');
        toggleButton.innerHTML = toggleButton.textContent.includes('Dark')
          ? '☀️ Light'
          : '🌙 Dark';
      });
    </script>
  </body>
</html>
